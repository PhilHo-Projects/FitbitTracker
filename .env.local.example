NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://health_hub:health_hub_dev@127.0.0.1:54329/health_hub
DASHBOARD_PASSWORD=0000
DASHBOARD_SESSION_SECRET=replace-with-a-long-random-local-secret
JOURNAL_ENCRYPTION_KEYS=1:replace-with-a-base64-encoded-32-byte-key
N8N_WEBHOOK_URL=https://n8n.philippeho.dev/webhook/health-hub-sync
N8N_WEBHOOK_TOKEN=replace-with-the-n8n-header-auth-token
SYNC_SCHEDULE_ENABLED=false

# Set true only when DATABASE_URL points to a database you manage separately.
SKIP_LOCAL_DATABASE=false
