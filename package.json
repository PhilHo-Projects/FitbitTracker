{
  "name": "fitbit-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Private Google Health archive for sleep, heart rate, calories, journal context, and exports.",
  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./public/styles.css --minify",
    "build:workflow": "node scripts/build-n8n-workflow.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:live": "npm run dev",
    "dev:fixtures": "node scripts/dev.mjs --fixtures",
    "dev:app": "node --watch server.js",
    "preview": "npm run build && node scripts/preview-fixtures.mjs",
    "migrate": "node scripts/migrate.mjs",
    "seed": "node scripts/seed.mjs",
    "start": "node scripts/start.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "pg": "^8.16.3",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "pg-mem": "^3.0.5",
    "tailwindcss": "^3.4.4"
  }
}
