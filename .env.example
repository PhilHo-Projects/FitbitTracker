# Coolify/runtime example. Local fixture development needs no copied env file:
# `npm run dev` supplies safe local defaults.
NODE_ENV=production
PORT=3000

# PostgreSQL is the authoritative health archive.
DATABASE_URL=postgres://health_hub:replace-me@postgres:5432/health_hub
DATABASE_POOL_SIZE=5
DATABASE_SSL=false

# The secured n8n Google Health gateway.
N8N_WEBHOOK_URL=https://n8n.philippeho.dev/webhook/health-hub-sync
N8N_WEBHOOK_TOKEN=replace-with-a-separate-random-token

# Local development keeps automatic sync scheduling disabled. Production uses a bounded schedule.
SYNC_SCHEDULE_ENABLED=true
SYNC_INTERVAL_HOURS=6
SYNC_SCHEDULE_LOOKBACK_DAYS=2
RAW_RETENTION_DAYS=90
HEALTH_COMPACT_WRITES_ENABLED=false
HEALTH_RAW_PRUNING_ENABLED=false
HEALTH_COMPACT_BACKFILL_BATCH_SIZE=1000

# Private dashboard sign-in. Use long, unrelated values in production.
DASHBOARD_PASSWORD=replace-with-a-strong-password
DASHBOARD_SESSION_SECRET=replace-with-at-least-32-random-characters

# Comma-separated versioned AES-256-GCM keys: version:base64-encoded-32-byte-key.
JOURNAL_ENCRYPTION_KEYS=1:replace-with-a-base64-encoded-32-byte-key

# Private temporary export storage. Completed files are deleted after 24 hours.
EXPORT_STORAGE_DIR=/app/.runtime/exports
