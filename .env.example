# Copy to .env for local dev (it's gitignored). Coolify sets these in its UI/API.
PORT=3000

# The n8n webhook the dashboard pulls from.
N8N_WEBHOOK_URL=https://n8n.philippeho.dev/webhook/fitness-sync

# Private dashboard sign-in. Use long, unrelated values in production.
DASHBOARD_PASSWORD=replace-with-a-strong-password
DASHBOARD_SESSION_SECRET=replace-with-at-least-32-random-characters

# Must match the value in n8n's "FitbitTracker Webhook Auth" Header Auth credential.
N8N_WEBHOOK_TOKEN=replace-with-a-separate-random-token
