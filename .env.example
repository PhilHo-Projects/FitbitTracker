# Copy to .env for local dev (it's gitignored). Coolify sets these in its UI/API.
PORT=3000

# The n8n webhook the dashboard pulls from.
N8N_WEBHOOK_URL=https://n8n.philippeho.dev/webhook/fitness-sync

# Shared token sent as the x-fitness-token header. Leave blank for the first test pass
# (the workflow does not enforce it yet). Set a random value here AND in the workflow's
# "Verify token" node to harden later.
N8N_WEBHOOK_TOKEN=
